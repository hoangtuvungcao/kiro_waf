#!/usr/sbin/nft -f

flush table inet kiro

table inet kiro {
  set admin_allow {
    type ipv4_addr
    flags interval
    elements = { 203.0.113.10 }
  }

  set cloudflare_v4 {
    type ipv4_addr
    flags interval
    elements = {
      173.245.48.0/20,
      103.21.244.0/22,
      103.22.200.0/22,
      103.31.4.0/22,
      141.101.64.0/18,
      108.162.192.0/18,
      190.93.240.0/20,
      188.114.96.0/20,
      197.234.240.0/22,
      198.41.128.0/17,
      162.158.0.0/15,
      104.16.0.0/13,
      104.24.0.0/14,
      172.64.0.0/13,
      131.0.72.0/22
    }
  }

  set cloudflare_v6 {
    type ipv6_addr
    flags interval
    elements = {
      2400:cb00::/32,
      2606:4700::/32,
      2803:f800::/32,
      2405:b500::/32,
      2405:8100::/32,
      2a06:98c0::/29,
      2c0f:f248::/32
    }
  }

  set temp_ban {
    type ipv4_addr
    flags timeout
  }

  set bad_subnet {
    type ipv4_addr
    flags interval,timeout
  }

  chain preraw {
    type filter hook prerouting priority raw; policy accept;

    ip saddr @temp_ban drop
    ip saddr @bad_subnet drop

    ip saddr { 0.0.0.0/8, 10.0.0.0/8, 100.64.0.0/10, 127.0.0.0/8, 169.254.0.0/16, 172.16.0.0/12, 192.0.2.0/24, 192.168.0.0/16, 198.18.0.0/15, 198.51.100.0/24, 203.0.113.0/24, 224.0.0.0/4, 240.0.0.0/4 } drop

    tcp flags & (fin|syn|rst|psh|ack|urg) == 0 drop
    tcp flags & (fin|syn) == (fin|syn) drop
    tcp flags & (syn|rst) == (syn|rst) drop

    meta l4proto udp drop
  }

  chain input {
    type filter hook input priority filter; policy drop;

    iif lo accept
    ct state established,related accept
    ct state invalid drop

    ip protocol icmp limit rate 5/second burst 10 packets accept

    tcp dport 22 ip saddr @admin_allow accept

    # Full mode with Cloudflare origin lock: HTTP/HTTPS only from Cloudflare.
    tcp dport { 80, 443 } ip saddr @cloudflare_v4 accept
    tcp dport { 80, 443 } ip6 saddr @cloudflare_v6 accept

    # Drop direct public HTTP/HTTPS to avoid origin IP bypass.
    tcp dport { 80, 443 } drop

    reject with icmpx type port-unreachable
  }
}
